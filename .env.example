# ─────────────────────────────────────────────────────────────────────────────
# Core LLM (Groq / OpenAI-compatible)
# ─────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────────────────────────────────────
# Gmail (optional — mock mode works without)
# ─────────────────────────────────────────────────────────────────────────────
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# ─────────────────────────────────────────────────────────────────────────────
# Telegram (optional)
# ─────────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Playwright Job Scraping & Auto-Apply
# ─────────────────────────────────────────────────────────────────────────────
# Headless mode (true for servers, false to watch the browser)
PLAYWRIGHT_HEADLESS=true
# Slow down each action by N ms (useful when debugging non-headless)
PLAYWRIGHT_SLOW_MO_MS=0
# Use locally-installed Chrome/Edge instead of bundled Chromium
# (recommended on corporate networks where Chromium download is SSL-blocked)
PLAYWRIGHT_USE_SYSTEM_CHROME=true
# Per-source scrape timeout (seconds)
SCRAPE_TIMEOUT_S=60

# ─────────────────────────────────────────────────────────────────────────────
# Job site credentials (only required for logged-in features like LinkedIn
# Easy Apply or Naukri full Quick Apply). Public search works without these.
# ─────────────────────────────────────────────────────────────────────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
NAUKRI_EMAIL=
NAUKRI_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# Auto-Apply defaults (used by FieldMapper to fill application forms)
# ─────────────────────────────────────────────────────────────────────────────
USER_CURRENT_CTC=
USER_EXPECTED_CTC=
USER_NOTICE_PERIOD=30 days
USER_LINKEDIN_URL=
# Default mode: auto | semi-auto | review | dry-run
AUTO_APPLY_MODE=semi-auto
